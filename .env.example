# -----------------------------------------------------------------------------
# Telegram bot
# -----------------------------------------------------------------------------
# Required. Bot token from @BotFather.
BOT_TOKEN=123456:telegram-bot-token

# Required. Telegram IDs of admins, comma-separated.
ADMIN_IDS=123456789,987654321

# Optional. Public Telegram Bot API by default.
# To use tdlib/tdlight local Bot API, set:
# COMPOSE_PROFILES=telegram-local
# TELEGRAM_API_BASE_URL=http://telegram-bot-api:8081
# TELEGRAM_FILE_BASE_URL=http://telegram-bot-api:8081/file
# TELEGRAM_LOCAL_MODE=true
COMPOSE_PROFILES=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_FILE_BASE_URL=https://api.telegram.org/file
TELEGRAM_LOCAL_MODE=false

# Required only when COMPOSE_PROFILES=telegram-local.
# Get them at https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_VERBOSITY=2

# Optional path rewrite for local Bot API --local mode.
# Use it when getFile returns a path from the Bot API container, but the bot
# sees the same shared volume mounted at another path.
TELEGRAM_LOCAL_PATH_PREFIX=
TELEGRAM_BOT_PATH_PREFIX=


# -----------------------------------------------------------------------------
# Nextcloud
# -----------------------------------------------------------------------------
# Required. Public URL shown to users.
NEXTCLOUD_URL=https://cloud.example.com

# Optional. URL used by the bot for OCS/WebDAV requests.
# Leave empty to use NEXTCLOUD_URL.
# Examples:
# NEXTCLOUD_INTERNAL_URL=http://nextcloud
# NEXTCLOUD_INTERNAL_URL=http://host.docker.internal
# NEXTCLOUD_INTERNAL_URL=https://cloud.example.com
NEXTCLOUD_INTERNAL_URL=

# Optional. Used by docker-compose extra_hosts to route the public domain to host-gateway.
# Helpful when bot and Nextcloud are on the same server.
NEXTCLOUD_HOSTNAME=cloud.example.com

# Required. Nextcloud admin login and app password.
# Create an app password in Nextcloud Security settings; do not use a normal session password.
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=nextcloud-admin-app-password

# Default quota for newly approved users.
DEFAULT_QUOTA_GB=10


# -----------------------------------------------------------------------------
# Database and cache
# -----------------------------------------------------------------------------
POSTGRES_DB=bot
POSTGRES_USER=bot
POSTGRES_PASSWORD=change-me-please
POSTGRES_SSLMODE=disable

# Redis is used for transient Telegram states.
REDIS_URL=redis://redis:6379/0

# Optional. If set, saved Nextcloud user passwords are encrypted before storing in PostgreSQL.
# Use a long random value and keep it stable; changing it will make encrypted passwords unreadable.
DATABASE_SECRET_KEY=
BACKUP_DIR=backups
LOG_DIR=logs
LOG_LEVEL=info

# Admin alerts.
NOTIFY_ADMINS_ON_START=true
NOTIFY_ADMINS_ON_CRASH=true


# -----------------------------------------------------------------------------
# User interface blocks
# -----------------------------------------------------------------------------
# Set false to remove the Support button completely.
ENABLE_SUPPORT_BLOCK=true
SUPPORT_TELEGRAM=@support_username
SUPPORT_EMAIL=support@example.com

# Set false to remove the Donate button completely.
ENABLE_DONATE_BLOCK=true


# -----------------------------------------------------------------------------
# Donations: Telegram Stars
# -----------------------------------------------------------------------------
# Separate donation section. Set false to hide Stars but keep other donation methods.
TELEGRAM_STARS_ENABLED=true
TELEGRAM_STARS_AMOUNTS=50,100,250


# -----------------------------------------------------------------------------
# Donations: Platega
# -----------------------------------------------------------------------------
# Separate donation section. Set false to hide Platega but keep other donation methods.
PLATEGA_ENABLED=true

# Optional static payment link. If API credentials are filled, the bot creates
# per-user Platega links and uses this only as an extra fallback button.
PLATEGA_URL=

# Optional API mode. Values are available in the Platega dashboard/settings.
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
PLATEGA_BASE_URL=https://app.platega.io
PLATEGA_AMOUNTS_RUB=100,300,500
PLATEGA_RETURN_URL=
PLATEGA_FAILED_URL=

# Public callback URL for Platega webhooks.
# Example: https://your-domain.example/webhooks/platega
# Also add the same URL in Platega dashboard callback settings.
PLATEGA_CALLBACK_URL=

# Public domain without path. Used to build callback URLs for providers that
# receive callback URL during invoice creation, for example Heleket.
PUBLIC_WEBHOOK_BASE_URL=https://your-domain.example
WEBHOOK_LISTEN_ADDR=:8088
PLATEGA_WEBHOOK_PATH=/webhooks/platega
WEBHOOK_PORT=8088


# -----------------------------------------------------------------------------
# Payments: Pally
# -----------------------------------------------------------------------------
# Docs: https://pally.info/en/merchant/api
PALLY_ENABLED=false
PALLY_TOKEN=
PALLY_SHOP_ID=
PALLY_BASE_URL=https://pal24.pro
PALLY_CALLBACK_PATH=/webhooks/pally


# -----------------------------------------------------------------------------
# Payments: CryptoBot / Crypto Pay
# -----------------------------------------------------------------------------
# Docs: https://help.send.tg/en/articles/10279948-crypto-pay-api
# Put a secret random segment into CRYPTOBOT_WEBHOOK_PATH and set the same URL
# in @CryptoBot -> Crypto Pay -> My Apps -> Webhooks.
CRYPTOBOT_ENABLED=false
CRYPTOBOT_TOKEN=
CRYPTOBOT_BASE_URL=https://pay.crypt.bot
CRYPTOBOT_WEBHOOK_PATH=/webhooks/cryptobot-change-this-secret


# -----------------------------------------------------------------------------
# Payments: Heleket
# -----------------------------------------------------------------------------
# Docs: https://doc.heleket.com/
HELEKET_ENABLED=false
HELEKET_MERCHANT_ID=
HELEKET_API_KEY=
HELEKET_BASE_URL=https://api.heleket.com
HELEKET_CURRENCY=RUB
HELEKET_TO_CURRENCY=USDT
HELEKET_WEBHOOK_PATH=/webhooks/heleket

# Optional generic external donation URL.
DONATE_URL=


# -----------------------------------------------------------------------------
# Background jobs and limits
# -----------------------------------------------------------------------------
# Compressed backups are kept for this many days.
BACKUP_RETENTION_DAYS=7

# Automatic PostgreSQL backup interval.
AUTO_BACKUP_INTERVAL_HOURS=24

# Interval for checking that approved users still exist in Nextcloud.
NEXTCLOUD_SYNC_INTERVAL_MINUTES=60

# Number of parallel upload workers. Supporters still get higher queue priority.
UPLOAD_WORKERS=3

# Per-user quota cache TTL. Set lower if you want fresher UI, higher if Nextcloud is slow.
QUOTA_CACHE_SECONDS=45

# Telegram Bot API download limit for files uploaded through the bot.
# Public Bot API should stay near 20 MB. With local Bot API --local mode, use up to 2000.
TELEGRAM_MAX_DOWNLOAD_MB=20

# Premium icon duration after a Stars/Platega payment or manual admin grant.
PREMIUM_DAYS=30


# -----------------------------------------------------------------------------
# Stickers
# -----------------------------------------------------------------------------
# Custom stickers are saved here, not in env, so they survive restarts.
STICKER_STORE_FILE=data/stickers.json

# Editable user messages/buttons are saved here.
CONTENT_STORE_FILE=data/content.json

# Test sticker pack shown in admin sticker setup.
STICKER_PACK_URL=https://t.me/addemoji/CPT_Emoji
