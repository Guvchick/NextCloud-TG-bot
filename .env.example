BOT_TOKEN=123456:telegram-bot-token
ADMIN_IDS=123456789,987654321

NEXTCLOUD_URL=https://cloud.example.com
# Optional: internal address used by the bot when Nextcloud is on the same server.
# Examples:
# NEXTCLOUD_INTERNAL_URL=http://nextcloud
# NEXTCLOUD_INTERNAL_URL=http://host.docker.internal
NEXTCLOUD_INTERNAL_URL=
# Optional: map your public Nextcloud hostname to the Docker host.
# Use this when HTTPS only works for the public domain, but bot and Nextcloud are on one server.
NEXTCLOUD_HOSTNAME=cloud.example.com
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=nextcloud-app-password

DEFAULT_QUOTA_GB=10
DATABASE_PATH=data/bot.sqlite3
BACKUP_DIR=backups
LOG_DIR=logs
UPLOAD_FOLDER=Telegram uploads
SUPPORT_TELEGRAM=@support_username
SUPPORT_EMAIL=support@example.com
DONATE_URL=https://example.com/donate

# Optional: enables automatic Boosty supporter icon.
# Users link their Boosty email in the bot, then sync marks active supporters automatically.
BOOSTY_ACCESS_TOKEN=
BOOSTY_SUBSCRIBERS_URL=https://api.boosty.to/v1/blog/getapp/subscribers
BOOSTY_SYNC_INTERVAL_MINUTES=60
BACKUP_RETENTION_DAYS=7
AUTO_BACKUP_INTERVAL_HOURS=24
NEXTCLOUD_SYNC_INTERVAL_MINUTES=60
TELEGRAM_MAX_DOWNLOAD_MB=20

# Optional custom Telegram sticker file_id values. If unset or invalid, bot uses built-in emoji markers.
STICKER_WELCOME=
STICKER_APPROVED=
STICKER_UPLOAD_OK=
STICKER_ERROR=
